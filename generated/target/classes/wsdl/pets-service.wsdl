<?xml version="1.0" encoding="UTF-8"?>
<wsdl:definitions xmlns:wsdl="http://schemas.xmlsoap.org/wsdl/"
                  xmlns:soap="http://schemas.xmlsoap.org/wsdl/soap/"
                  xmlns:tns="http://com.example.petstore/ws/pets"
                  targetNamespace="http://com.example.petstore/ws/pets"
                  name="PetsService">

    <wsdl:types><xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema">
        <!-- types defined in schema.xsd -->
    </xs:schema></wsdl:types>

    <wsdl:message name="ListPetsRequest">
        <wsdl:part name="parameters" element="tns:ListPetsRequest"/>
    </wsdl:message>
    <wsdl:message name="ListPetsResponse">
        <wsdl:part name="parameters" element="tns:ListPetsResponse"/>
    </wsdl:message>

    <wsdl:message name="CreatePetRequest">
        <wsdl:part name="parameters" element="tns:CreatePetRequest"/>
    </wsdl:message>
    <wsdl:message name="CreatePetResponse">
        <wsdl:part name="parameters" element="tns:CreatePetResponse"/>
    </wsdl:message>

    <wsdl:message name="GetPetByIdRequest">
        <wsdl:part name="parameters" element="tns:GetPetByIdRequest"/>
    </wsdl:message>
    <wsdl:message name="GetPetByIdResponse">
        <wsdl:part name="parameters" element="tns:GetPetByIdResponse"/>
    </wsdl:message>

    <wsdl:message name="UpdatePetRequest">
        <wsdl:part name="parameters" element="tns:UpdatePetRequest"/>
    </wsdl:message>
    <wsdl:message name="UpdatePetResponse">
        <wsdl:part name="parameters" element="tns:UpdatePetResponse"/>
    </wsdl:message>

    <wsdl:message name="DeletePetRequest">
        <wsdl:part name="parameters" element="tns:DeletePetRequest"/>
    </wsdl:message>
    <wsdl:message name="DeletePetResponse">
        <wsdl:part name="parameters" element="tns:DeletePetResponse"/>
    </wsdl:message>

    <wsdl:portType name="PetsServicePort">
        <wsdl:operation name="ListPets">
            <wsdl:input message="tns:ListPetsRequest"/>
            <wsdl:output message="tns:ListPetsResponse"/>
        </wsdl:operation>
        <wsdl:operation name="CreatePet">
            <wsdl:input message="tns:CreatePetRequest"/>
            <wsdl:output message="tns:CreatePetResponse"/>
        </wsdl:operation>
        <wsdl:operation name="GetPetById">
            <wsdl:input message="tns:GetPetByIdRequest"/>
            <wsdl:output message="tns:GetPetByIdResponse"/>
        </wsdl:operation>
        <wsdl:operation name="UpdatePet">
            <wsdl:input message="tns:UpdatePetRequest"/>
            <wsdl:output message="tns:UpdatePetResponse"/>
        </wsdl:operation>
        <wsdl:operation name="DeletePet">
            <wsdl:input message="tns:DeletePetRequest"/>
            <wsdl:output message="tns:DeletePetResponse"/>
        </wsdl:operation>
    </wsdl:portType>

    <wsdl:binding name="PetsServiceBinding" type="tns:PetsServicePort">
        <soap:binding style="document" transport="http://schemas.xmlsoap.org/soap/http"/>
        <wsdl:operation name="ListPets">
            <soap:operation soapAction="http://com.example.petstore/ws/pets/ListPets"/>
            <wsdl:input><soap:body use="literal"/></wsdl:input>
            <wsdl:output><soap:body use="literal"/></wsdl:output>
        </wsdl:operation>
        <wsdl:operation name="CreatePet">
            <soap:operation soapAction="http://com.example.petstore/ws/pets/CreatePet"/>
            <wsdl:input><soap:body use="literal"/></wsdl:input>
            <wsdl:output><soap:body use="literal"/></wsdl:output>
        </wsdl:operation>
        <wsdl:operation name="GetPetById">
            <soap:operation soapAction="http://com.example.petstore/ws/pets/GetPetById"/>
            <wsdl:input><soap:body use="literal"/></wsdl:input>
            <wsdl:output><soap:body use="literal"/></wsdl:output>
        </wsdl:operation>
        <wsdl:operation name="UpdatePet">
            <soap:operation soapAction="http://com.example.petstore/ws/pets/UpdatePet"/>
            <wsdl:input><soap:body use="literal"/></wsdl:input>
            <wsdl:output><soap:body use="literal"/></wsdl:output>
        </wsdl:operation>
        <wsdl:operation name="DeletePet">
            <soap:operation soapAction="http://com.example.petstore/ws/pets/DeletePet"/>
            <wsdl:input><soap:body use="literal"/></wsdl:input>
            <wsdl:output><soap:body use="literal"/></wsdl:output>
        </wsdl:operation>
    </wsdl:binding>

    <wsdl:service name="PetsService">
        <wsdl:port name="PetsServicePort" binding="tns:PetsServiceBinding">
            <soap:address location="http://localhost:8080/ws"/>
        </wsdl:port>
    </wsdl:service>

</wsdl:definitions>
